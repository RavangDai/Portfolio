# Copy this file to `.env.local` and fill in real values. NEVER commit `.env.local`.
# All values below are placeholders.

# ── Contact form (SMTP) ───────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=your-gmail-app-password
CONTACT_TO=you@example.com
CONTACT_FROM="Your Name <you@example.com>"

# ── Chatbot ───────────────────────────────────────────────────────────────────
# Google Gemini API key (absent -> chatbot returns a "not configured" message).
GEMINI_API_KEY=your-gemini-api-key
# Optional GitHub PAT — lifts GitHub API rate limit from 60 to 5000/hr.
GITHUB_TOKEN=your-github-personal-access-token

# ── Admin auth ────────────────────────────────────────────────────────────────
ADMIN_EMAIL=you@example.com
# bcrypt hash. In `.env.local` you MUST escape every $ as \$ or @next/env
# variable-expansion silently corrupts it at runtime. Generate via scripts/gen-admin-hash.mjs.
ADMIN_PASSWORD_HASH=\$2b\$12\$replace-with-your-own-bcrypt-hash
# Signs/verifies admin sessions. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=generate-a-32-byte-random-hex-string

# ── Vercel Blob (content storage + uploads) ───────────────────────────────────
# Without this the site serves DEFAULT_CONTENT read-only.
BLOB_READ_WRITE_TOKEN=your-vercel-blob-rw-token

# ── Rate limiting (Upstash Redis REST) ────────────────────────────────────────
# When both are set, admin login AND the public /api/chat + /api/contact routes are
# throttled server-side per client IP — uncheatable by dropping cookies. Without them
# (local dev) login uses a signed-cookie fallback and public routes use a best-effort
# in-memory limiter. Set these in production. Get them from https://console.upstash.com/
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token

# ── SEO (optional) ────────────────────────────────────────────────────────────
# Canonical origin for metadata/sitemap/JSON-LD. Defaults to https://bibek.tech.
# NEXT_PUBLIC_SITE_URL=https://your-domain.com
# Google Search Console verification token (injects the meta tag when set).
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your-token
